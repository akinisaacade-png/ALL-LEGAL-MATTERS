rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow users to read and write their own profile and subscription data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Allow access to subscription tiers or global application configurations publicly
    match /subscriptions/{subscriptionId} {
      allow read: if true; // Allow all users to view available plans
      allow write: if request.auth != null; // Allow authenticated users to update their plan status
    }

    // Allow access to Europe core jurisdictions directory
    match /jurisdictions_europe_core/{jurisdictionId} {
      allow read: if true; // Public access
      allow write: if request.auth != null; // Registered users or admins
    }
    
    // Admin override rules for the AdminConsole components
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }
  }
}
